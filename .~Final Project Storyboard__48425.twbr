    <dashboard enable-sort-zone-taborder='true' name='Data Collection'>
      <style />
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone forceUpdate='true' h='98000' id='3' type-v2='text' w='98400' x='800' y='1000'>
            <formatted-text>
              <run bold='true' fontcolor='#000000' fontsize='20'>Data Collection &amp; Cleaning</run>
              <run>Æ&#10;&#10;</run>
              <run fontcolor='#000000' fontsize='16'>• Pulled ACS income data using tidycensus</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='16'>• Pulled ACS rent data using tidycensus</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='16'>• Pulled CPI data from FRED using tidyquant</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='16'>• Adjusted 2010 dollar values for inflation</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='16'>• Merged datasets in R using state names</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='16'>• Created rent-to-income ratios for 2010 and 2024</run>
              <run>Æ&#10;</run>
              <run fontcolor='#000000' fontsize='16'>• Validated missing values, duplicates, and impossible values</run>
